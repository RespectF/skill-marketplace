{
  "framework": null,
  "buildCommand": "vite build && esbuild api/index.ts --platform=node --packages=external --bundle --format=esm --outfile=api/index.js --minify",
  "outputDirectory": "dist/public",
  "routes": [
    { "src": "/api/trpc/(.*)", "dest": "/api/index.js" },
    { "src": "/api/test", "dest": "/api/index.js" }
  ]
}
