{
  "framework": null,
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "routes": [
    { "src": "/api", "dest": "/api/index.ts" },
    { "src": "/api/trpc", "dest": "/api/index.ts" },
    { "src": "/api/trpc/(.*)", "dest": "/api/index.ts" },
    { "src": "/api/(.*)", "dest": "/api/index.ts" }
  ]
}
