{
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build && esbuild api/[...slug].ts --platform=node --bundle --format=esm --outfile=api/[...slug].js --minify",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
